# Copy this file to .env and fill in your values
# Never commit .env to git — it contains secrets

# Your Neon database connection string
# Get this from: neon.tech → your project → Connection Details → Connection string
DATABASE_URL=postgresql://username:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Your Vercel frontend URL (no trailing slash)
# Example: https://lumen-abc123.vercel.app
FRONTEND_URL=https://your-lumen-app.vercel.app

# Port to run on locally (Railway sets this automatically in production)
PORT=3001
